# =============================
# GitaVerse environment template
# =============================
# Copy this file to .env for local use.

# Core AI key (server-side)
ANTHROPIC_API_KEY=

# CAPTCHA (Cloudflare Turnstile)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Shared rate-limit store (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional tuning (defaults shown)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_PER_IP=12
RATE_LIMIT_MAX_PER_FP=8
DAILY_QUOTA_PER_IP=120
DAILY_QUOTA_PER_FP=60
AI_TIMEOUT_MS=12000
